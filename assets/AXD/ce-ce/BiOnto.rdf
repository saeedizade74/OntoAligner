                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#isRelatedTo"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Change"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#isRelatedTo"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Market"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
