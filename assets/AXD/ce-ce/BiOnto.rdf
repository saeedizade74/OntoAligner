    <!-- http://ontorion.com/namespace#UnitedStates -->

    <owl:Class rdf:about="http://ontorion.com/namespace#UnitedStates">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://ontorion.com/namespace#Country"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#hasName"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
