    <!-- http://ontorion.com/namespace#AcademicDiscipline -->

    <owl:Class rdf:about="http://ontorion.com/namespace#AcademicDiscipline">
        <owl:equivalentClass rdf:resource="http://ontorion.com/namespace#AcademicField"/>
        <rdfs:subClassOf rdf:resource="http://ontorion.com/namespace#Knowledge"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#isTaughtIn"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#College"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#isTaughtIn"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#University"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label>AcademicDiscipline</rdfs:label>
    </owl:Class>
    


