            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#breaksDown"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#OrganicMaterial"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#consumes"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#BiochemicalOxygenDemand"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://ontorion.com/namespace#contains"/>
                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Water"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://ontorion.com/namespace#has"/>
                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Metabolism"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://ontorion.com/namespace#livesThrought"/>
                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Nutrient"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://ontorion.com/namespace#isMadeOf"/>
                <owl:allValuesFrom rdf:resource="http://ontorion.com/namespace#Cell"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#MultiCellularOrganism"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#UnicellularOrganism"/>
        </owl:disjointUnionOf>
        <rdfs:label>Organism</rdfs:label>
    </owl:Class>
    


