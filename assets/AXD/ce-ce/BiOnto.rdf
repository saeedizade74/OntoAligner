                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#BiobasedProduct"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#BusinessCase"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#GoToMarket"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#MarketAcceleration"/>
        </owl:disjointUnionOf>
        <rdfs:label>MarketDevelopmentPhase</rdfs:label>
    </owl:Class>
    


