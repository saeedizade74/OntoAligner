                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#concerns"/>
                        <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                        <owl:onClass rdf:resource="http://ontorion.com/namespace#Activity"/>
