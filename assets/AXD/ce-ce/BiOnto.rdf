                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Matter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#ArtificialMaterial"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#NaturalMaterial"/>
        </owl:disjointUnionOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#Ceramic"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#Glass"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#Hybrid"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#Metal"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#Polymer"/>
        </owl:disjointUnionOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#CombustibleMaterial"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#NonCombustibleMaterial"/>
        </owl:disjointUnionOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#NonOrganicMaterial"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#OrganicMaterial"/>
        </owl:disjointUnionOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#Raw"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#SemiFinished"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#Waste"/>
        </owl:disjointUnionOf>
