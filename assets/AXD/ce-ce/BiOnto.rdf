    <!-- http://ontorion.com/namespace#Matter -->

    <owl:Class rdf:about="http://ontorion.com/namespace#Matter">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#isMadeOf"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="http://ontorion.com/namespace#ChemicalSubstance"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#hasMass"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#hasVolume"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#Gas"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#Liquid"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#Plasma"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#Solid"/>
        </owl:disjointUnionOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#ImpureMatter"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#PureMatter"/>
        </owl:disjointUnionOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#InorganicMatter"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#OrganicMatter"/>
        </owl:disjointUnionOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://ontorion.com/namespace#LivingThing"/>
            <rdf:Description rdf:about="http://ontorion.com/namespace#NonLivingThing"/>
        </owl:disjointUnionOf>
        <rdfs:label>Matter</rdfs:label>
    </owl:Class>
    


