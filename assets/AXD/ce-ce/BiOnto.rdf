    <!-- http://ontorion.com/namespa#BottomUpDesign -->

    <owl:Class rdf:about="http://ontorion.com/namespa#BottomUpDesign">
        <rdfs:subClassOf rdf:resource="http://ontorion.com/namespace#Strategy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://ontorion.com/namespace#hasProcess"/>
                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Information"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Bottom-upDesign</rdfs:label>
    </owl:Class>
    


    <!-- http://ontorion.com/namespa#HumanComputerInteraction -->

    <owl:Class rdf:about="http://ontorion.com/namespa#HumanComputerInteraction">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#concerns"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Technology"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#concerns"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#User"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label>Human-computerInteraction</rdfs:label>
    </owl:Class>
    


    <!-- http://ontorion.com/namespa#LifeCycleAssessment -->

    <owl:Class rdf:about="http://ontorion.com/namespa#LifeCycleAssessment">
        <rdfs:subClassOf rdf:resource="http://ontorion.com/namespace#Method"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#concerns"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Product"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#studies"/>
                        <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#EnvironmentalImpact"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label>Life-cycleAssessment</rdfs:label>
    </owl:Class>
    


    <!-- http://ontorion.com/namespa#LowCarbonEconomy -->

    <owl:Class rdf:about="http://ontorion.com/namespa#LowCarbonEconomy">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://ontorion.com/namespace#DecarbonisedEconomy"/>
                    <rdf:Description rdf:about="http://ontorion.com/namespace#LowFossilFuelEconomy"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://ontorion.com/namespace#Economy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://ontorion.com/namespace#minimizes"/>
                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#CarbonDioxide"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Low-carbonEconomy</rdfs:label>
    </owl:Class>
    


    <!-- http://ontorion.com/namespa#NonGovernmentalOrganization -->

    <owl:Class rdf:about="http://ontorion.com/namespa#NonGovernmentalOrganization">
        <rdfs:label>Non-governmentalOrganization</rdfs:label>
    </owl:Class>
    


    <!-- http://ontorion.com/namespa#SecondGenerationBiofuel -->

    <owl:Class rdf:about="http://ontorion.com/namespa#SecondGenerationBiofuel">
        <owl:equivalentClass rdf:resource="http://ontorion.com/namespace#AdvancedBiofuel"/>
        <rdfs:subClassOf rdf:resource="http://ontorion.com/namespace#Biofuel"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://ontorion.com/namespace#isProducedFrom"/>
                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Biomas"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Second-generationBiofuel</rdfs:label>
    </owl:Class>
    


    <!-- http://ontorion.com/namespa#TopDownDesign -->

    <owl:Class rdf:about="http://ontorion.com/namespa#TopDownDesign">
        <rdfs:subClassOf rdf:resource="http://ontorion.com/namespace#Strategy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://ontorion.com/namespace#hasProcess"/>
                <owl:someValuesFrom rdf:resource="http://ontorion.com/namespace#Information"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Top-downDesign</rdfs:label>
    </owl:Class>
    


