            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://ontorion.com/namespace#Combustion"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://ontorion.com/namespace#uses"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="http://ontorion.com/namespace#Material"/>
