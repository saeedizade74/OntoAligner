    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasMassFractionOfDismantableComponentsForReuseAndRecycle -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasMassFractionOfDismantableComponentsForReuseAndRecycle">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/statement/hasQuantityInterval"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/DismantlingStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
        <rdfs:label>has mass fraction of dismantable components for reuse and recycle</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasMassFractionOfPostConsumerRecycledMaterialsOutOfTheTotalProductMass -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasMassFractionOfPostConsumerRecycledMaterialsOutOfTheTotalProductMass">
