    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasQuantityInterval -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasQuantityInterval">
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
