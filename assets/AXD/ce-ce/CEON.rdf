        <rdfs:label>Water Reuse Or Recirculation Statement</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/EconomicValue -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/EconomicValue">
        <owl:equivalentClass rdf:resource="http://w3id.org/CEON/ontology/value/UseValue"/>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
        <rdfs:comment>Use/Economics value represents how a thing (e.g., a product or service) match some goals or needs of an actor under some circumstances.</rdfs:comment>
        <rdfs:label>Economic Value</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/EnvironmentalValue -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/EnvironmentalValue">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
        <rdfs:comment>Environmental value represents how a thing (e.g., a product or service) match some environmental goals or needs of an actor under some circumstances.</rdfs:comment>
        <rdfs:label>Environmental Value</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/ExchangeValue -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/ExchangeValue">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
        <rdfs:comment>Exchange value represents the worth of a product, resource, service in a exchange setting, i.e., a product, resource, service is traded or sold.</rdfs:comment>
        <rdfs:label>Exchange Value</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/SocialValue -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/SocialValue">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
        <rdfs:comment>Social value represents how a thing (e.g., a product or service) match some social goals or needs of an actor under some circumstances.</rdfs:comment>
        <rdfs:label>Social Value</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/UseValue -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/UseValue">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
        <rdfs:comment>Use/Economics value represents how a thing (e.g., a product or service) match some goals or needs of an actor under some circumstances.</rdfs:comment>
        <rdfs:label>Use Value</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/Value -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/Value">
        <rdfs:comment xml:lang="en">Gain(s) or benefit(s) from satisfying needs and expectations,	in relation to the use	and conservation of resources. EXAMPLE: Revenue, savings, productivity, sustainability, satisfaction, empowerment, engagement, experience, public health, trust. Value is relative to, and determined by the perception of, those interested party(ies) able to capture it. Value can be financial or non-financial, e.g. social, environmental, other gains or benefits. Value is dynamic over time.</rdfs:comment>
        <rdfs:isDefinedBy>ISO 59004:2024 - 3.1.7 value</rdfs:isDefinedBy>
        <rdfs:label>Value</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/ValueParticipation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/ValueParticipation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/value/hasAssociatedValue"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A participation that may create/destory/miss value.</rdfs:comment>
        <rdfs:label>Value Participation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/ValueParticipationRole -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/ValueParticipationRole">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/Role"/>
        <rdfs:comment>A role that a value participant can take.</rdfs:comment>
        <rdfs:label>Value Participation Role</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/ValuePerception -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/ValuePerception">
        <rdfs:comment>Value perception of an actor determines specifc values.</rdfs:comment>
        <rdfs:label>Value Perception</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/value/ValueProposition -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/value/ValueProposition">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/value/hasAimedValue"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/value/targettingActor"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/value/targettingValueParticipation"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/value/ValueParticipation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Proposed or intended value outcome of some process, action or collaboration.</rdfs:comment>
        <rdfs:label>Value Proposition</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry">
        <skos:definition xml:lang="en">A coherent set of direct positions in space. The positions are held within a Spatial Reference System (SRS).</skos:definition>
        <skos:prefLabel xml:lang="en">Geometry</skos:prefLabel>
    </owl:Class>
    


