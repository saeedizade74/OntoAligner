    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasVolumeFractionOfReductionOfDirectWaterConsumptionUsedInProduction -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasVolumeFractionOfReductionOfDirectWaterConsumptionUsedInProduction">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/statement/hasQuantityInterval"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/WaterReuseOrRecirculationStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
        <rdfs:label>has volume fraction of reduction of direct water consumption used in production</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasVolumeFractionOfReusedOrRecirculatedWaterUsedInProduction -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasVolumeFractionOfReusedOrRecirculatedWaterUsedInProduction">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/statement/hasQuantityInterval"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/WaterReuseOrRecirculationStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
        <rdfs:label>has volume fraction of reused or recirculated water used in production</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/statementAbout -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/statementAbout">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/Statement"/>
        <rdfs:comment>Generic property to express what the statement is about, i.e. what is involved in the statement.</rdfs:comment>
        <rdfs:label>statement about</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/hasAimedValue -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/hasAimedValue">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValueProposition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
        <rdfs:comment>A value proposition has specific aimed values.</rdfs:comment>
        <rdfs:label>has aimed value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/hasAssociatedValue -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/hasAssociatedValue">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValuePerception"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
        <rdfs:comment>A value perception about creating/destoring/missing some value.</rdfs:comment>
        <rdfs:label>has associated value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/hasPerception -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/hasPerception">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/Actor"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/value/ValueProposition"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/value/ValuePerception"/>
        <rdfs:comment>An actor perceive specific values, or a value proposition is about specific values.</rdfs:comment>
        <rdfs:label>has perception</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/hasVPTargets -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/hasVPTargets">
        <rdfs:comment>A value proposition is proposed about specific actors, participations or resources.</rdfs:comment>
        <rdfs:label>has value proposition targets</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/hasValuableResource -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/hasValuableResource">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValueParticipation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:comment>A value participation has participating resources.</rdfs:comment>
        <rdfs:label>has valuable resource</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/hasValueParticipantRole -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/hasValueParticipantRole">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValueParticipation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/value/ValueParticipationRole"/>
        <rdfs:comment>Holds the value of the role of the value participant in this value participation relation.</rdfs:comment>
        <rdfs:label>has value participant role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/onValueParticipation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/onValueParticipation">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValuePerception"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/value/ValueParticipation"/>
        <rdfs:comment>A perception is on specific value participations.</rdfs:comment>
        <rdfs:label>on value participation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/proposedBy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/proposedBy">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValueProposition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
        <rdfs:comment>A value proposition is proposed by specific actors.</rdfs:comment>
        <rdfs:label>proposed by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/targettingActor -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/targettingActor">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/value/hasVPTargets"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValueProposition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
        <rdfs:comment>A value proposition is about some actors.</rdfs:comment>
        <rdfs:label>targetting actor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/targettingResource -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/targettingResource">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/value/hasVPTargets"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValueProposition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:comment>A value proposition is about some resources.</rdfs:comment>
        <rdfs:label>targetting resource</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/value/targettingValueParticipation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/value/targettingValueParticipation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/value/hasVPTargets"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/value/ValueProposition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/value/ValueParticipation"/>
        <rdfs:comment>A value proposition is about some participation.</rdfs:comment>
        <rdfs:label>targetting value participation</rdfs:label>
    </owl:ObjectProperty>
    


