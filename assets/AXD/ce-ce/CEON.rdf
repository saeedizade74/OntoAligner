<?xml version="1.0"?>
<rdf:RDF xmlns="http://w3id.org/CEON/ontology/full/"
     xml:base="http://w3id.org/CEON/ontology/full/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:qudt="http://qudt.org/schema/qudt/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vaem="http://www.linkedmodel.org/schema/vaem#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:quantity="http://w3id.org/CEON/ontology/quantity#"
     xmlns:statement="http://w3id.org/CEON/ontology/statement/"
     xmlns:cpannotationschema="http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#">
    <owl:Ontology rdf:about="http://w3id.org/CEON/ontology/full/">
        <owl:versionIRI rdf:resource="http://w3id.org/CEON/ontology/full/0.2/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/actor/0.4/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/actorODP/0.4/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/cvn/0.3/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/energy/0.2/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/location/0.2/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/material/0.4/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/process/0.5/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/product/0.5/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/quantity/0.2/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/statement/0.2/"/>
        <owl:imports rdf:resource="http://w3id.org/CEON/ontology/value/0.3/"/>
        <dcterms:contributor>Eva Blomqvist</dcterms:contributor>
        <dcterms:contributor>Huanyu Li</dcterms:contributor>
        <dcterms:contributor>Mikael Lindecrantz</dcterms:contributor>
        <dcterms:contributor>Robin Keskisärkkä</dcterms:contributor>
        <dcterms:created>2025-06-12</dcterms:created>
        <dcterms:creator>Huanyu Li</dcterms:creator>
        <dcterms:license>https://github.com/LiUSemWeb/CEON/blob/master/LICENSE</dcterms:license>
        <dcterms:title>Circular Economy Ontology Network (CEON) - Full</dcterms:title>
        <vann:preferredNamespacePrefix>actor</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>actorODP</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>cvn</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>energy</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>full</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>location</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>material</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>process</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>processODP</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>product</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>quantity</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>qudt</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>qudt-unit</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>resourceODP</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>statement</vann:preferredNamespacePrefix>
        <vann:preferredNamespacePrefix>value</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://qudt.org/2.1/schema/qudt#</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://qudt.org/vocab/unit</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/actor/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/energy/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/full/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/material/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/processODP/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/product/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/quantity/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/resourceODP/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontology/statement/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontoloy/actorODP/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontoloy/cvn/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>http://w3id.org/CEON/ontoloy/location/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>https://w3id.org/CEON/ontology/process/</vann:preferredNamespaceUri>
        <vann:preferredNamespaceUri>https://w3id.org/CEON/ontoloy/value/</vann:preferredNamespaceUri>
        <vaem:description>Standard units of measure for all units.</vaem:description>
        <rdfs:seeAlso>https://github.com/LiUSemWeb/CEON</rdfs:seeAlso>
        <owl:versionInfo>0.2</owl:versionInfo>
    </owl:Ontology>
    
    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://qudt.org/schema/qudt/hasQuantityKind -->

    <owl:ObjectProperty rdf:about="http://qudt.org/schema/qudt/hasQuantityKind">
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityKind"/>
        <rdfs:isDefinedBy rdf:resource="http://qudt.org/2.1/schema/qudt"/>
        <rdfs:label xml:lang="en">has quantity kind</rdfs:label>
        <rdfs:label>has quantity kind</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://qudt.org/schema/qudt/hasUnit -->

    <owl:ObjectProperty rdf:about="http://qudt.org/schema/qudt/hasUnit"/>
    


    <!-- http://qudt.org/schema/qudt/quantityValue -->

    <owl:ObjectProperty rdf:about="http://qudt.org/schema/qudt/quantityValue">
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:isDefinedBy rdf:resource="http://qudt.org/2.1/schema/qudt"/>
        <rdfs:label>quantity value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actor/capabilityExtent -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actor/capabilityExtent">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/capabilityProperty"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Capability"/>
        <rdfs:comment>The extent of this capability, e.g. stating whether there are limist to the capability, such as a maximum amount or size of something.</rdfs:comment>
        <rdfs:label>capability extent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actor/hasOrganisationLocation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actor/hasOrganisationLocation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasLocation"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actor/Organisation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/actor/OrganisationLocation"/>
        <rdfs:comment>Represent that an organisation has some locations.</rdfs:comment>
        <rdfs:label>has organisation location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actor/neededResourceRelation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actor/neededResourceRelation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/capabilityProperty"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Capability"/>
        <rdfs:comment>In order for an actor to have a capability, it needs to have certain resources, e.g. materials, infrastrucutre, know-how, information etc.</rdfs:comment>
        <rdfs:label>needed resource relations</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/actorType -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/actorType">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/actorODP/ActorType"/>
        <rdfs:comment>The type of the actor.</rdfs:comment>
        <rdfs:label>actor type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/basedOnCapability -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/basedOnCapability">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/CollaborationParticipation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/actorODP/Capability"/>
        <rdfs:comment>An actor participates in a collaboration based on that it has some capability that is useful for the collaboration.</rdfs:comment>
        <rdfs:label>based on capability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/capabilityOf -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/capabilityOf">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Capability"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/Actor"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/Infrastructure"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>Relates to the actor holding the capability.</rdfs:comment>
        <rdfs:label>capability of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/capabilityProperty -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/capabilityProperty">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Capability"/>
        <rdfs:comment>Relates some properties to the capability, such as the parameters of it, or the needed resources.</rdfs:comment>
        <rdfs:label>capability property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participantRole -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participantRole">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/actorODP/Role"/>
        <rdfs:comment>Holds the value of the role of the participant in this participation relation.</rdfs:comment>
        <rdfs:label>participant role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participatingActor -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participatingActor">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
        <rdfs:comment>Holds the value of the actor involved in this participation relation.</rdfs:comment>
        <rdfs:label>participating actor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participatingObject -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participatingObject">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceParticipation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:comment>Participating object in a resource participation. This is part of a resource participation that can be a directional relation, and the participating object is the end point of the relation.</rdfs:comment>
        <rdfs:label>participating object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participatingResource -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participatingResource">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:comment>The resource that this participation relation relates to, i.e. for which the actor holds the specified role.</rdfs:comment>
        <rdfs:label>participating resource</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participatingSubject -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participatingSubject">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceParticipation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:comment>Participating subject in a resource participation. This is part of a resource participation that can be a directional relation, and the participating subject is the starting point of the relation.</rdfs:comment>
        <rdfs:label>participating subject</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participating_infrastructure -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participating_infrastructure">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/actorODP/Infrastructure"/>
        <rdfs:comment>Holds the value of the infrastructure involved in this participation relation.</rdfs:comment>
        <rdfs:label>participating infrastructure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participationIn -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participationIn">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/CollaborationParticipation"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/cvn/Collaboration"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/Process"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>The collaboration or process that this participation relates to.</rdfs:comment>
        <rdfs:label>is a participation in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/cvn/aimsAtValue -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/cvn/aimsAtValue">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/cvn/CVN"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/cvn/CVNBlueprint"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/value/ValueProposition"/>
        <rdfs:comment>The value proposition that the planned abstract CVN configuration, or concrete network wants to achieve.</rdfs:comment>
        <rdfs:label>aims at value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/cvn/composedOf -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/cvn/composedOf">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/cvn/CVN"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/Process"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/cvn/CVN"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/Process"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>Both a CVN and a process can be composed of other CVNs or processes.</rdfs:comment>
        <rdfs:label>composed of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/cvn/createsValue -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/cvn/createsValue">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/Participation"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/cvn/CVN"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/Process"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/value/Value"/>
        <rdfs:comment>Value creation can be captured at the actor level, i.e. value created by an actor&apos;s participation in a collaboration, or at the process or complete CVN level.</rdfs:comment>
        <rdfs:label>creates value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/cvn/implementsBlueprint -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/cvn/implementsBlueprint">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/cvn/CVN"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/cvn/CVNBlueprint"/>
        <rdfs:comment>The blueprint (or plan) that this concrete CVN is an instance of.</rdfs:comment>
        <rdfs:label>implements blueprint</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/cvn/implementsStrategy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/cvn/implementsStrategy">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/cvn/relatedStrategy"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/cvn/CVN"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/cvn/CircularStrategy"/>
        <rdfs:comment>A strategy that is implemented by this CVN or CVN blueprint.</rdfs:comment>
        <rdfs:label>implements strategy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/cvn/plansToImplementStrategy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/cvn/plansToImplementStrategy">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/cvn/relatedStrategy"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/cvn/CVNBlueprint"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/cvn/CircularStrategy"/>
        <rdfs:comment>A strategy that is planned to be implemented by this CVN or CVN blueprint.</rdfs:comment>
        <rdfs:label>plans to implement strategy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/cvn/relatedStrategy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/cvn/relatedStrategy">
        <rdfs:comment>A strategy that is targeted by this CVN or CVN blueprint.</rdfs:comment>
        <rdfs:label>related strategy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/hasAnergy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/energy/hasAnergy">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/participatingObject"/>
        <rdfs:comment>hasAnergy represents that energy has part of anergy.</rdfs:comment>
        <rdfs:label>has anergy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/hasConvertedEnergy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/energy/hasConvertedEnergy">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/participatingResource"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/energy/NonRenewableEnergy"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/energy/RenewableEnergy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>hasConvertedEnergy represents that an energy transformation process has its final energy.</rdfs:comment>
        <rdfs:label>has converted energy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/hasEnergySource -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/energy/hasEnergySource">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/energy/Energy"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/energy/EnergySource"/>
        <rdfs:comment>hasEnergySource represents that energy can have some energy sources.</rdfs:comment>
        <rdfs:label>has energy source</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/hasExergy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/energy/hasExergy">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/participatingObject"/>
        <rdfs:comment>hasExergy represents that energy has part of exergy.</rdfs:comment>
        <rdfs:label>has exergy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/hasOriginalEnergy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/energy/hasOriginalEnergy">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/participatingResource"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/energy/NonRenewableEnergy"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/energy/RenewableEnergy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>hasOriginalEnergy represents that an energy transformation process has its initial energy.</rdfs:comment>
        <rdfs:label>has original energy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/participatingEnergy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/energy/participatingEnergy">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/participatingSubject"/>
        <rdfs:comment>participatingEnergy represents the energy in an energy composition.</rdfs:comment>
        <rdfs:label>participating energy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/location/hasLocation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/location/hasLocation">
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:comment>Represents the location of an actor or resource.</rdfs:comment>
        <rdfs:label>has location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/material/hasChemicalEntity -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/material/hasChemicalEntity">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/material/Material"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/material/ChemicalEntity"/>
        <rdfs:comment>hasChemicalEntity intends to represent that a material can have a collection of chemical entities.</rdfs:comment>
        <rdfs:label>has chemical entity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/material/hasMaterialComponent -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/material/hasMaterialComponent">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/material/Material"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/material/MaterialComponent"/>
        <rdfs:comment>hasMaterialComponent intends to represent that a material can have a collection of components.</rdfs:comment>
        <rdfs:label>has material component</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/process/needsEnergy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/process/needsEnergy">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/hasInput"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/energy/Energy"/>
        <rdfs:comment>The energy needed to perform a certain process.</rdfs:comment>
        <rdfs:label>needs energy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/process/producesCO2 -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/process/producesCO2">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/hasOutput"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/process/CO2Emission"/>
        <rdfs:comment>The CO2 released or produced by the process.</rdfs:comment>
        <rdfs:label>produces CO2</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/process/resultingResource -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/process/resultingResource">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/hasOutput"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:comment>The resource that is the output (product, i.e. what is produced) from a certain process.</rdfs:comment>
        <rdfs:label>resulting resource</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/process/usesCatalyst -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/process/usesCatalyst">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/hasInput"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/process/Catalyst"/>
        <rdfs:comment>The catalyst used in a process.</rdfs:comment>
        <rdfs:label>uses catalyst</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/affectedObject -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/affectedObject">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/isSettingFor"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/Transition"/>
        <rdfs:comment>The object that is affected by a certain transition, e.g. material that changes its state from one situation to another.</rdfs:comment>
        <rdfs:label>affected object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/duringTime -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/duringTime">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/isSettingFor"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/Transition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/processODP/TimeInterval"/>
        <rdfs:comment>The time interval during which a transition takes place.</rdfs:comment>
        <rdfs:label>during time</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/followsExecution -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/followsExecution">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/isSettingFor"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/PlanExecution"/>
        <rdfs:comment>The situation after the execution takes place, i.e. the state of affairs after the process event, such as the product being assembled, or the material being recycled.</rdfs:comment>
        <rdfs:label>follows execution</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/hasInput -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/hasInput">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/Process"/>
        <rdfs:comment>The inputs to this process event.</rdfs:comment>
        <rdfs:label>has input</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/hasOutput -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/hasOutput">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/Process"/>
        <rdfs:comment>The output to this process event.</rdfs:comment>
        <rdfs:label>has output</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/hasPart -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/hasPart">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/Plan"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/PlanExecution"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/Plan"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/PlanExecution"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>A plan or execution can consists of several parts, which are sub-plans (or execution steps).</rdfs:comment>
        <rdfs:label>has part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/hasPlanExecution -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/hasPlanExecution">
        <owl:inverseOf rdf:resource="http://w3id.org/CEON/ontology/processODP/satisfiesPlan"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/Plan"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/processODP/PlanExecution"/>
        <rdfs:comment xml:lang="en">A plan can have specific executions.</rdfs:comment>
        <rdfs:label xml:lang="en">has plan execution</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/isSettingFor -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/isSettingFor">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/Situation"/>
        <rdfs:comment>The thing(s) that this situation is the setting for, e.g. a resource that is in a certain state.</rdfs:comment>
        <rdfs:label>is the setting for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/occursAtLocation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/occursAtLocation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/isSettingFor"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:comment>The location in which something (e.g. an execution/transition) takes place, e.g. the factory location where something is manufactured.</rdfs:comment>
        <rdfs:label>occurs at location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/precedesExecution -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/precedesExecution">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/processODP/isSettingFor"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/PlanExecution"/>
        <rdfs:comment>The situation before the process event takes place, i.e. the state of affairs before the execution, such as the state of the set of components before they are assembled into a product item, or the material state before being recycled.</rdfs:comment>
        <rdfs:label>precedes execution</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/satisfiesPlan -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/processODP/satisfiesPlan">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/Situation"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/processODP/Description"/>
        <rdfs:comment>A relation between a Situation and a Description, e.g. the execution of a Plan satisfies that plan.</rdfs:comment>
        <rdfs:label>satisfies plan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/associatedWithMatter -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/associatedWithMatter">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/MatterComposition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Matter"/>
        <rdfs:comment>associatedWithMatter intends to represent the matter to which a matter compopsition information regards to.</rdfs:comment>
        <rdfs:label>associated with matter</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/associatedWithProductModel -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/associatedWithProductModel">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/ProductComposition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/Product"/>
        <rdfs:comment>associatedWithProductModel intends to represent the product model to which a product compopsition information regards to.</rdfs:comment>
        <rdfs:label>associated with product model</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/associatedWithProductObject -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/associatedWithProductObject">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/ProductObjectComposition"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/Item"/>
        <rdfs:comment>associatedWithProductObject intends to represent the item (product object) to which a product object compopsition information regards to.</rdfs:comment>
        <rdfs:label>associated with product object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/batchOfProduct -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/batchOfProduct">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/BatchOfObjects"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/Product"/>
        <rdfs:comment>batchOfProduct intends to represent what is the model product of a batch of objects.</rdfs:comment>
        <rdfs:label>batch of products</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/complianceWith -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/complianceWith">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/Compliance"/>
        <rdfs:comment>Represents what the compliance is compliant with (e.g. a standard or regulation).</rdfs:comment>
        <rdfs:label>compliance with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/compositionOf -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/compositionOf">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/Composition"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Item"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Product"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/resourceODP/Matter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>Represents what the composition is a composition of (i.e., the product, the product object or matter that is broken down into its components).</rdfs:comment>
        <rdfs:label>composition of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasAssemblyLocation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/hasAssemblyLocation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasLocation"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Item"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Product"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/AssemblyLocation"/>
        <rdfs:comment>Used to represent the location of assembly of a product or product object (item).</rdfs:comment>
        <rdfs:label>has assembly location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasCompliance -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/hasCompliance">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/Actor"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/processODP/Process"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Item"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Product"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/Compliance"/>
        <rdfs:comment>Used to link something (e.g., product or process) to a compliance.</rdfs:comment>
        <rdfs:label>has compliance</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasComposition -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/hasComposition">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Product"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/Composition"/>
        <rdfs:comment>hasComposition intends to represent that a product model or physical object can have compostition information.</rdfs:comment>
        <rdfs:label>has composition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasManufacturerLocation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/hasManufacturerLocation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasLocation"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Item"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Product"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/ManufactureLocation"/>
        <rdfs:comment>Used to represent the location of manufacturer of a product or product object (item).</rdfs:comment>
        <rdfs:label>has manufacture location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasOriginLocation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/hasOriginLocation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasLocation"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Item"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/product/Product"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/OriginLocation"/>
        <rdfs:comment>Used to represent the location of origin of a product or product object (item).</rdfs:comment>
        <rdfs:label>has origin location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasProductComponent -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/hasProductComponent">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/Product"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/Product"/>
        <rdfs:comment>hasProductComponent intends to represent that a product can have other product components.</rdfs:comment>
        <rdfs:label>has product component</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasProductObjectComponent -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/hasProductObjectComponent">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/Item"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/Item"/>
        <rdfs:label>has product object component</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/modelledBy -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/product/modelledBy">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/Item"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/product/Product"/>
        <rdfs:comment>modelledBy intends to represent that product objects follow particular product models.</rdfs:comment>
        <rdfs:label>modelled by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasDimension -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasDimension">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:comment>hasDimension is used to describe a dimension of a product or product object.</rdfs:comment>
        <rdfs:label>has dimension</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasDismantlingCost -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasDismantlingCost">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasProcessCost"/>
        <rdfs:comment>The cost of dismantling, expressed as an amount of money with a currency unit.</rdfs:comment>
        <rdfs:label>has dismantling cost</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasHeight -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasHeight">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasDimension"/>
        <rdfs:comment>hasHeight is used to describe the height of a product or product object.</rdfs:comment>
        <rdfs:label>has height</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasLength -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasLength">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasDimension"/>
        <rdfs:comment>hasLength is used to describe the length of a product or product object.</rdfs:comment>
        <rdfs:label>has length</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasMarketValue -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasMarketValue">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:comment>The market value, expressed as an amount of money with a currency unit.</rdfs:comment>
        <rdfs:label>has market value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasMaximalValueIncludedOfInterval -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasMaximalValueIncludedOfInterval">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/quantity/QuantityInterval"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment>represents the maximum value (included) of an interval</rdfs:comment>
        <rdfs:label>has maximal value included of interval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasMaximalValueNotIncludedOfInterval -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasMaximalValueNotIncludedOfInterval">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/quantity/QuantityInterval"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment>represents the maximum value (not included) of an interval</rdfs:comment>
        <rdfs:label>has maximal value not included of interval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasMinimalValueIncludedOfInterval -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasMinimalValueIncludedOfInterval">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/quantity/QuantityInterval"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment>represents the minimal value (included) of an interval</rdfs:comment>
        <rdfs:label>has minimal value included of interval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasMinimalValueNotIncludedOfInterval -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasMinimalValueNotIncludedOfInterval">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/quantity/QuantityInterval"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment>represents the minimal value (not included) of an interval</rdfs:comment>
        <rdfs:label>has minimal value not included of interval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasPrice -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasPrice">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:comment>represents that sth has a specific cost</rdfs:comment>
        <rdfs:label>has price</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasProcessCost -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasProcessCost">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:comment>represents that a process can have a cost</rdfs:comment>
        <rdfs:label>has process cost</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasRecyclingCost -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasRecyclingCost">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasProcessCost"/>
        <rdfs:comment>The cost of recycling, expressed as an amount of money with a currency unit.</rdfs:comment>
        <rdfs:label>has recycling cost</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasRefurbishmentCost -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasRefurbishmentCost">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasProcessCost"/>
        <rdfs:comment>The cost of refurbishment, expressed as an amount of money with a currency unit.</rdfs:comment>
        <rdfs:label>has refurbishment cost</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasTestingCost -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasTestingCost">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasProcessCost"/>
        <rdfs:comment>The cost of testing, expressed as an amount of money with a currency unit.</rdfs:comment>
        <rdfs:label>has testing cost</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasThickness -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasThickness">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasDimension"/>
        <rdfs:comment>hasThickness is used to describe the thickness of a product or product object.</rdfs:comment>
        <rdfs:label>has thickness</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasTransportCost -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasTransportCost">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasProcessCost"/>
        <rdfs:comment>The cost of transportation, expressed as an amount of money with a currency unit.</rdfs:comment>
        <rdfs:label>has transport cost</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasVolume -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasVolume">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:comment>represents the volume of an object</rdfs:comment>
        <rdfs:label>has volume</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasWeight -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasWeight">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/quantityValue"/>
        <rdfs:comment>represents the weight of an object</rdfs:comment>
        <rdfs:label>has weight</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/hasWidth -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/hasWidth">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/quantity/hasDimension"/>
        <rdfs:comment>hasWidth is used to describe the width of a product or product object.</rdfs:comment>
        <rdfs:label>has width</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/quantity/objectValue -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/quantity/objectValue">
        <rdfs:subPropertyOf rdf:resource="http://qudt.org/schema/qudt/hasQuantityKind"/>
        <rdfs:comment>objectValue is analogous to qudt:numericalValue</rdfs:comment>
        <rdfs:label>object value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/containsInformation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/containsInformation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasPart"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Information"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Information"/>
        <rdfs:comment>Indicating that some piece of information is contained in a larger collection of information, e.g. a data sheet contains a statement about a certain parameter of a product.</rdfs:comment>
        <rdfs:label>contains information</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasBatch -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasBatch">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/SetOfObjects"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/BatchOfObjects"/>
        <rdfs:comment>hasBatch intends to represent that a set of objects can be captured by a number of batches where each batch contains a number of physical objects.</rdfs:comment>
        <rdfs:label>has batch</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasConstituent -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasConstituent">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasPart"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Constituent"/>
        <rdfs:comment>hasConstitutent intends to represent that a physical object can have a collection of composing components.</rdfs:comment>
        <rdfs:label>has constituent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasMatter -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasMatter">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Matter"/>
        <rdfs:comment>hasMatter intends to represent that a physical object can have a collection of matter.</rdfs:comment>
        <rdfs:label>has matter</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasPart -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasPart">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment>Indicating that something is part of or is contained by something else.</rdfs:comment>
        <rdfs:label>has part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasPhysicalObject -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasPhysicalObject">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/resourceODP/BatchOfObjects"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/resourceODP/SetOfObjects"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject"/>
        <rdfs:comment>hasPhysicalObject intends to represent that a batch of objects or a set of objects can have composing components of physical objects.</rdfs:comment>
        <rdfs:label>has physical object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasResourceCondition -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasResourceCondition">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceCondition"/>
        <rdfs:comment>A resource can has specifc conditions.</rdfs:comment>
        <rdfs:label>has resource condition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasResourceLocation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasResourceLocation">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasLocation"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:comment>Defines the location of a resource.</rdfs:comment>
        <rdfs:label>has resource location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasResourceProperty -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasResourceProperty">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceProperty"/>
        <rdfs:comment>A resource can has specifc properties.</rdfs:comment>
        <rdfs:label>has resource property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/hasResourceQuality -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/hasResourceQuality">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceQuality"/>
        <rdfs:comment>A resource can has specifc qualities.</rdfs:comment>
        <rdfs:label>has resource quality</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/isAbout -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/isAbout">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Information"/>
        <rdfs:comment>Connecting the information to the object (physical, virtual, imaginary) that the information is about.</rdfs:comment>
        <rdfs:label>is about</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/isRealizationOf -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/resourceODP/isRealizationOf">
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Information"/>
        <rdfs:comment>Relates a thing, e.g. a digital object, or a physical object, to the information it is a realization of. C.f. a physical book that is the realization of a novel, or a pdf or Excel-file that is a realization of a certain data sheet.</rdfs:comment>
        <rdfs:label>is realization of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasAvailability -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasAvailability">
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/statement/Availability"/>
        <rdfs:label>has availability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasChemicalSubstanceThresholdUsedByManufacturer -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasChemicalSubstanceThresholdUsedByManufacturer">
