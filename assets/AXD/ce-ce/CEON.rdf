                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/statement/hasVolumeFractionOfReductionOfDirectWaterConsumptionUsedInProduction"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/statement/75gt-95le"/>
