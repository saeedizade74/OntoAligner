        <qudt:ucumCode rdf:datatype="http://qudt.org/schema/qudt/UCUMcs">dm2</qudt:ucumCode>
        <qudt:uneceCommonCode>DMK</qudt:uneceCommonCode>
        <rdfs:isDefinedBy rdf:resource="http://qudt.org/2.1/vocab/unit"/>
