    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasMassFractionOfReusedPartsOutOfTheTotalProduct -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasMassFractionOfReusedPartsOutOfTheTotalProduct">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/statement/hasQuantityInterval"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/ReusedContentStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
        <rdfs:label>has mass fraction of reused parts out of the total product</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasPostConsumerRecycledMaterialCompositionThreshold -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasPostConsumerRecycledMaterialCompositionThreshold">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/statement/hasQuantityInterval"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/RecycledMaterialStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
        <rdfs:label>has post consumer recycled material composition threshold</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasPreConsumerRecycledMaterialCompositionThreshold -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasPreConsumerRecycledMaterialCompositionThreshold">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/statement/hasQuantityInterval"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/RecycledMaterialStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
