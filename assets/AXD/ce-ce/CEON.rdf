    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://qudt.org/schema/qudt/numericValue -->

    <owl:DatatypeProperty rdf:about="http://qudt.org/schema/qudt/numericValue"/>
    


    <!-- http://w3id.org/CEON/ontology/actor/hasOrganisationName -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/actor/hasOrganisationName">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actor/Organisation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>Represent name of an organisation.</rdfs:label>
        <rdfs:label>has organisation name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participationEndTime -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participationEndTime">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#dateTime"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#gMonthYear"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment>The end of a time interval.</rdfs:comment>
        <rdfs:label>participation end time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participationStartTime -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participationStartTime">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#dateTime"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#gMonthYear"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment>The start of a time interval.</rdfs:comment>
        <rdfs:label>participation start time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/participationTimePoint -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/actorODP/participationTimePoint">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#dateTime"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#gMonthYear"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment>The point in time when something took place or was valid.</rdfs:comment>
        <rdfs:label>participation time point</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/hasCarbonIntensity -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/energy/hasCarbonIntensity">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/energy/EnergySource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>hasCarbonIntensity measures how intensive that the carbon is for an energy source.</rdfs:comment>
        <rdfs:label>has carbon intensity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/hasEnergyComponentPercentage -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/energy/hasEnergyComponentPercentage">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/energy/EnergyComposition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>hasEnergyComponentPercentage represents the percentage of a particular energy as a composition.</rdfs:comment>
        <rdfs:label>has energy component percentage</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/energy/hasSustainability -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/energy/hasSustainability">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/energy/EnergySource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>has sustainability</rdfs:label>
        <rdfs:label>hasSustainability measures how sustainable an energy source is.</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/location/hasCity -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/location/hasCity">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Represents the name of a city.</rdfs:comment>
        <rdfs:label>has city</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/location/hasCountry -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/location/hasCountry">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Represents the name of a country.</rdfs:comment>
        <rdfs:label>has country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/location/hasCountryCode -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/location/hasCountryCode">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Represents the code of a country&apos;s name according to ISO 3166-1.</rdfs:comment>
        <rdfs:label>has country code</rdfs:label>
        <rdfs:seeAlso>ISO 3166-1 (Codes for the representation of names of countries and their subdivisions – Part 1: Country code)</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/location/hasGlobalLocationNumber -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/location/hasGlobalLocationNumber">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The Global Location Number (GLN) is part of the GS1 systems of standards.</rdfs:comment>
        <rdfs:label>has global location number</rdfs:label>
        <rdfs:seeAlso>https://www.gs1.org/standards/id-keys/gln</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/location/hasPostalCode -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/location/hasPostalCode">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Represent postal code</rdfs:comment>
        <rdfs:label>has postal code</rdfs:label>
        <rdfs:seeAlso>Universal Postal Union (UPU) S42 standard</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/location/hasStreetAddress -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/location/hasStreetAddress">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Represents address of a street, including e.g., street number and name.</rdfs:comment>
        <rdfs:label>has street address</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/material/anonymousFormula -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/material/anonymousFormula">
        <rdfs:comment>anonymousFormula represents that a molecular entity has the anonymous formula in a string.</rdfs:comment>
        <rdfs:label>anonymous formula</rdfs:label>
        <rdfs:seeAlso>https://w3id.org/mdo/structure/AnonymousFormula</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/material/descriptiveFormula -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/material/descriptiveFormula">
        <rdfs:comment>descriptiveFormula represents that a molecular entity has the descriptive formula in a string.</rdfs:comment>
        <rdfs:label>descriptive formula</rdfs:label>
        <rdfs:seeAlso>https://w3id.org/mdo/structure/DescriptiveFormula</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/material/hillFormula -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/material/hillFormula">
        <rdfs:comment>hillFormula represents that a composition has the hill formula in a string.</rdfs:comment>
        <rdfs:label>hill formula</rdfs:label>
        <rdfs:seeAlso>https://w3id.org/mdo/structure/HillFormula</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/material/reducedChemicalFormula -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/material/reducedChemicalFormula">
        <rdfs:comment>reducedChemicalFormula represents that a molecular entity has the reduced chemical formula in a string.</rdfs:comment>
        <rdfs:label>reduced chemical formula</rdfs:label>
        <rdfs:seeAlso>https://w3id.org/mdo/structure/ReducedFormula</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/endTime -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/processODP/endTime">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/TimeInterval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Represents the end time of a time interval.</rdfs:comment>
        <rdfs:label>end time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/occursAtTime -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/processODP/occursAtTime">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/PlanExecution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Represents the time at which something takes place.</rdfs:comment>
        <rdfs:label>occurs at time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/processODP/startTime -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/processODP/startTime">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/processODP/TimeInterval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Represents the start time of a time interval.</rdfs:comment>
        <rdfs:label>start time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/compositionQuantity -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/product/compositionQuantity">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/Composition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>compositionQuantity represents the quantity of elements of a composition.</rdfs:comment>
        <rdfs:label>composition quantity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/countryOfAssembly -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/product/countryOfAssembly">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasCountry"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/AssemblyLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Used to represent the country of assembly of a product or product object (item).</rdfs:comment>
        <rdfs:label>Country of assembly</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/countryOfManufacture -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/product/countryOfManufacture">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasCountry"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/ManufactureLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Used to represent the country of manufacture of a product or product object (item).</rdfs:comment>
        <rdfs:label>Country of manufacture</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/countryOfOrigin -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/product/countryOfOrigin">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasCountry"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/OriginLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Used to represent the country of origin of a product or product object (item).</rdfs:comment>
        <rdfs:label>Country of origin</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/countryOfProduction -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/product/countryOfProduction">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/location/hasCountry"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/ProductionLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Used to represent the country of production of a product or product object (item).</rdfs:comment>
        <rdfs:label>Country of production</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasBrand -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/product/hasBrand">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The brand name of a product.</rdfs:comment>
        <rdfs:label>has brand</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasCertificate -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/product/hasCertificate">
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/product/Compliance"/>
        <rdfs:comment>Link to the the certificate that certifies the compliance</rdfs:comment>
        <rdfs:label>has certificate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://w3id.org/CEON/ontology/product/hasGlobalTradeItemNumber -->

    <owl:DatatypeProperty rdf:about="http://w3id.org/CEON/ontology/product/hasGlobalTradeItemNumber">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>Global Trade Item Number (GTIN)</rdfs:label>
