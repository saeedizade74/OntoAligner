        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/DemountingStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
        <rdfs:label>has mass fraction for demounting</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasMassFractionForDisassembly -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasMassFractionForDisassembly">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/CEON/ontology/statement/hasQuantityInterval"/>
        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/DisassemblyStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
        <rdfs:label>has mass fraction for disassembly</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasMassFractionOfAllDisclosedChemicalSubstance -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasMassFractionOfAllDisclosedChemicalSubstance">
