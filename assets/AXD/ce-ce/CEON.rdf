    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasValidation -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasValidation">
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/statement/Validation"/>
