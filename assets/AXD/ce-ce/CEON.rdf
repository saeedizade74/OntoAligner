        <rdfs:comment>A process of production.</rdfs:comment>
        <rdfs:label>Production Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/RecycleProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/RecycleProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of recycling.</rdfs:comment>
        <rdfs:label>Recycle Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/RefurbishmentProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/RefurbishmentProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of refurbishment.</rdfs:comment>
        <rdfs:label>Refurbishment Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/RemoveProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/RemoveProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of removing.</rdfs:comment>
        <rdfs:label>Remove Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/RemoveResourceProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/RemoveResourceProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of removing a resource.</rdfs:comment>
        <rdfs:label>Remove Resource Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/RepairProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/RepairProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of repairing.</rdfs:comment>
        <rdfs:label>Repair Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/ResellProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/ResellProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of reselling.</rdfs:comment>
        <rdfs:label>Resell Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/ReuseProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/ReuseProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of reusing.</rdfs:comment>
        <rdfs:label>Reuse Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/SellResourceProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/SellResourceProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of selling a resource.</rdfs:comment>
        <rdfs:label>Sell Resource Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/ServiceProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/ServiceProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of servicing.</rdfs:comment>
        <rdfs:label>Service Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/ShareResourceProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/ShareResourceProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of sharing a resource.</rdfs:comment>
        <rdfs:label>Share Resource Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/process/TakeBackProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/process/TakeBackProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
        <rdfs:comment>A process of taking back.</rdfs:comment>
        <rdfs:label>Take Back Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/Description -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/Description">
        <rdfs:comment>A Description is a SocialObject that represents a conceptualization. 
For example, a Plan is a Description of some actions to be executed by agents in a certain way, with certain parameters etc. Descriptions &apos;define&apos; or &apos;use&apos; concepts, and can be &apos;satisfied&apos; by situations.</rdfs:comment>
        <rdfs:label>Description</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/Event -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/Event">
        <rdfs:comment>Activities that take place within a given context or timeframe.</rdfs:comment>
        <rdfs:label>Event</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/Plan -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/Plan">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/hasPart"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/Plan"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A Description having an explicit goal, to be achieved by executing the plan.</rdfs:comment>
        <rdfs:label>Plan</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/PlanExecution -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/PlanExecution">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/Situation"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/duringTime"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/TimeInterval"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/occursAtTime"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/followsExecution"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/Situation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/hasPart"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/PlanExecution"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/isSettingFor"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/Process"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/precedesExecution"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/Situation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/satisfiesPlan"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/Plan"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Plan executions are situations that proactively satisfy a plan. Subplan executions are proper parts of the whole plan execution.</rdfs:comment>
        <rdfs:label>Plan Execution</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/Process -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/Process">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/Event"/>
        <rdfs:comment xml:lang="en">Set of interrelated or interacting activities that transforms inputs into outputs.</rdfs:comment>
        <rdfs:isDefinedBy>ISO 59004:2024  - 3.5.5 process</rdfs:isDefinedBy>
        <rdfs:label>Process</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/Situation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/Situation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/isSettingFor"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A situation that may involve some resources and actors, i.e. a state of affairs at a certain point in time.</rdfs:comment>
        <rdfs:label>Situation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/TimeInterval -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/TimeInterval">
        <rdfs:comment>A temporal entity has a starting time and an ending time.</rdfs:comment>
        <rdfs:label>Time Interval</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/TransformationProcess -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/TransformationProcess">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/Process"/>
        <rdfs:comment>A process that transforms some situation into another situation, i.e. changes the state of affairs of some actor, resource etc.</rdfs:comment>
        <rdfs:label>Transformation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/processODP/Transition -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/processODP/Transition">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/processODP/PlanExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/isSettingFor"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/TransformationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/processODP/affectedObject"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A transition is a situation that creates a context for two additional different Situations, one Process, and at least one Object: one Situation is the state before the transition, the second Situation is the state after the transition, the Process is the invariance under some different transitions, in which at least one Object is situated. Finally, one or more time interval(s) may position the situations and the transitional event in time, and we may include the event that triggered the transition as well.</rdfs:comment>
        <rdfs:label>Transition</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/AssemblyLocation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/AssemblyLocation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasCity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasPostalCode"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasStreetAddress"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/countryOfAssembly"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The location where a physical object is assembled.</rdfs:comment>
        <rdfs:label>Assembly Location</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/Compliance -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/Compliance">
        <rdfs:comment>Represents that something is compliant with some standard or has a received a certain certification.</rdfs:comment>
        <rdfs:label>Compliance</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/Composition -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/Composition">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceParticipation"/>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/ISOCompliance -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/ISOCompliance">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/product/Compliance"/>
        <rdfs:comment>ISO compliance is a compliance issuing thay sth (e.g., organization&apos;s structure, business operations, practices or policies) follows a specific ISO standard.</rdfs:comment>
        <rdfs:label>ISO Compliance</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/Item -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/Item">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/modelledBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://w3id.org/CEON/ontology/product/Product"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>An item is a physical object put into a market for sale, i.e. corresponding to an individual of a product. The item can be a thing that grows naturally or produced through some chemical or manufacturing processes.</rdfs:comment>
        <rdfs:label>Item</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/ManufactureLocation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/ManufactureLocation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasCity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasPostalCode"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasStreetAddress"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/countryOfManufacture"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The location where a physical object is manufactured.</rdfs:comment>
        <rdfs:label>Manufacture Location</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/MatterComposition -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/MatterComposition">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/product/Composition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/associatedWithMatter"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Matter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A product composition is the composed information of a product in terms of a specific component, in which such a component is also a matter.</rdfs:comment>
        <rdfs:label>Matter composition</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/OriginLocation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/OriginLocation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasCity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasPostalCode"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasStreetAddress"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/countryOfOrigin"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The origin location of a physical object</rdfs:comment>
        <rdfs:label>Origin Location</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/Product -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/Product">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/product/Solution"/>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/hasComposition"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/product/MatterComposition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/hasComposition"/>
                <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/product/ProductComposition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/hasAssemblyLocation"/>
                <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/product/AssemblyLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/hasManufacturerLocation"/>
                <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/product/ManufactureLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/hasOriginLocation"/>
                <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/product/OriginLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Physical-based object designed for or utilized with a purpose. A product can be, for example: goods of any type; hardware (e.g. engine mechanical part, spare parts, consumables); electrical or electronic hardware devices or components (e.g. computers, communication equipment and sensors); processed materials (e.g. lubricant, cement).</rdfs:comment>
        <rdfs:comment>Represents the common sense notion of a product, i.e. the abstract notion of a product type, which is a model that is used for manufacturing items of that product.</rdfs:comment>
        <rdfs:isDefinedBy>ISO 59004:2024 -3.2.2 product</rdfs:isDefinedBy>
        <rdfs:label>Product</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/ProductComposition -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/ProductComposition">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/product/Composition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/associatedWithProductModel"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://w3id.org/CEON/ontology/product/Product"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A product composition is the composed information of a product in terms of a specific component, in which such a component is also a product.</rdfs:comment>
        <rdfs:label>Product composition</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/ProductObjectComposition -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/ProductObjectComposition">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/product/Composition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/associatedWithProductObject"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://w3id.org/CEON/ontology/product/Item"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A product object composition is the composed information of a product object in terms of a specific component, in which such a component is also a product object.</rdfs:comment>
        <rdfs:label>Product Object Composition</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/ProductionLocation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/ProductionLocation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasCity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasPostalCode"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/location/hasStreetAddress"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/countryOfProduction"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/productionSite"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The production location of a physical object</rdfs:comment>
        <rdfs:label>Production Location</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/REACHCompliance -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/REACHCompliance">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/complianceWith"/>
                <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/product/REACH"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/product/Compliance"/>
        <rdfs:comment>REACH (Regulation on the registration, evaluation, authorisation and restriction of chemicals) compliance is a compliance issueing that the REACH regulation is satisfied.</rdfs:comment>
        <rdfs:label>REACH Compliance</rdfs:label>
        <rdfs:seeAlso>https://environment.ec.europa.eu/topics/chemicals/reach-regulation_en</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/Regulation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/Regulation">
        <rdfs:comment>The rules or restrictions made or maintained by authorities.</rdfs:comment>
        <rdfs:label>Regulation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/RoHSCompliance -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/RoHSCompliance">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/complianceWith"/>
                <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/product/RoHS"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/product/Compliance"/>
        <rdfs:comment>RoHS (Restriction of Hazardous Substances in Electrical and Electronic Equipment) compliance is a compliance issuing that RoHS objectives are satisfied.</rdfs:comment>
        <rdfs:label>RoHS Compliance</rdfs:label>
        <rdfs:seeAlso>https://environment.ec.europa.eu/topics/waste-and-recycling/rohs-directive_en</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/Solution -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/Solution">
        <rdfs:comment>Product or service, or a combination thereof, that fulfils a need of an interested party.</rdfs:comment>
        <rdfs:isDefinedBy>ISO 59004:2024 - 3.2.1 solution</rdfs:isDefinedBy>
        <rdfs:label>Solution</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/product/SupplierLocation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/product/SupplierLocation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:comment>The location of supplier of a product or item.</rdfs:comment>
        <rdfs:label>Supplier Location</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/quantity#QuantityInterval -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
    


    <!-- http://w3id.org/CEON/ontology/quantity/QuantityInterval -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/quantity/QuantityInterval">
        <rdfs:comment>Quantity interval is an interval with two quantity values.</rdfs:comment>
        <rdfs:label>Quantity Interval</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/Asset -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/Asset">
        <rdfs:comment>Asset is sth that is valuable and useful to be used in activities, or owned by actors.</rdfs:comment>
        <rdfs:label>Asset</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/BatchOfObjects -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/BatchOfObjects">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasPhysicalObject"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasPhysicalObject"/>
                        <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/product/batchOfProduct"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://w3id.org/CEON/ontology/product/Product"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/batchSize"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A batch of objects is a collection of physical objects that are of the same type, e.g. a set of items (product instances) adhering to the same product model.</rdfs:comment>
        <rdfs:label>Batch Of Objects</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/Constituent -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/Constituent">
        <rdfs:comment>A constituent is a component of object.</rdfs:comment>
        <rdfs:label>Constituent</rdfs:label>
        <rdfs:seeAlso>http://emmo.info/emmo#EMMO_ceaaf9f7_fd11_424b_8fda_9afa186af186</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/DigitalObject -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/DigitalObject">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:comment>A digital object, e.g. a computer file, that is located on some server, hard drive, or on the web. Most often the digital object is the realization of some piece of information.</rdfs:comment>
        <rdfs:label>Digital object</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/Information -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/Information">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Asset"/>
        <rdfs:comment>Information is an abstract concept that represents any kind of interpretations. For instance, information can be data generated by software systems or data used by people for communications.</rdfs:comment>
        <rdfs:label>Information</rdfs:label>
        <rdfs:seeAlso>http://emmo.info/emmo#EMMO_64c72d00_7582_44ea_a0b5_3a14e50acc36</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/Matter -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/Matter">
        <rdfs:comment>A matter is a physical substance.</rdfs:comment>
        <rdfs:label>Matter</rdfs:label>
        <rdfs:seeAlso>http://emmo.info/emmo#EMMO_5b2222df_4da6_442f_8244_96e9e45887d1</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/PhysicalObject -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasConstituent"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Constituent"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasConstituent"/>
                        <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Constituent"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasMatter"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Matter"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasMatter"/>
                        <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Matter"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A physical object is a collection of matter.</rdfs:comment>
        <rdfs:label>Physical object</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/Resource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/Resource">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Asset"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasResourceCondition"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceCondition"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasResourceCondition"/>
                        <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceCondition"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasResourceProperty"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceProperty"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasResourceProperty"/>
                        <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceProperty"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasResourceQuality"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceQuality"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasResourceQuality"/>
                        <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/ResourceQuality"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>Asset from which a solution is created or implemented. Depending on the context, reference to “resource” includes “raw material”, “feedstock”, “material” or “component”. Resource includes any energy type (e.g. the energy content or energy potential of materials). Note 4 to entry: Resources can be considered concerning both stocks and flows.</rdfs:comment>
        <rdfs:comment>Some resources can be specifically associated with processes.</rdfs:comment>
        <rdfs:isDefinedBy>ISO 59004:2024 - 3.1.5 resource</rdfs:isDefinedBy>
        <rdfs:label>Resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/ResourceCondition -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/ResourceCondition">
        <rdfs:comment>The status of a resource.</rdfs:comment>
        <rdfs:label>Resource Condition</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/ResourceProperty -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/ResourceProperty">
        <rdfs:comment>The characteristics or attribuets of a resource.</rdfs:comment>
        <rdfs:label>Resource Property</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/ResourceQuality -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/ResourceQuality">
        <rdfs:comment>Resource quality is derived based on assessments of resources considering the conditions and properties.</rdfs:comment>
        <rdfs:label>Resource Quality</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/resourceODP/SetOfObjects -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/resourceODP/SetOfObjects">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasBatch"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/BatchOfObjects"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/resourceODP/hasBatch"/>
