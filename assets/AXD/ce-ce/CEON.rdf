                        <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/PhysicalObject"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A set of objects is a set of physical objects (items) that can be of different types, i.e. different kinds of items.</rdfs:comment>
        <rdfs:label>Set of objects</rdfs:label>
    </owl:Class>
    


