        <rdfs:domain rdf:resource="http://w3id.org/CEON/ontology/statement/RenewableEnergyStatement"/>
        <rdfs:range rdf:resource="http://w3id.org/CEON/ontology/quantity#QuantityInterval"/>
        <rdfs:label>has fraction of renewable energy out of the total production energy mix</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/CEON/ontology/statement/hasMassFractionForDemounting -->

    <owl:ObjectProperty rdf:about="http://w3id.org/CEON/ontology/statement/hasMassFractionForDemounting">
