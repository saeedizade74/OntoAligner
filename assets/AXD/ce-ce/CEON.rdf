    <!-- http://w3id.org/CEON/ontology/actor/ManufacturingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/ManufacturingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/manufacturer"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the manufacturer of a certain resource.</rdfs:comment>
        <rdfs:label>Manufacturing resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/Organisation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/Organisation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actor/hasOrganisationLocation"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/actor/OrganisationLocation"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actor/hasOrganisationLocation"/>
                        <owl:allValuesFrom rdf:resource="http://w3id.org/CEON/ontology/actor/OrganisationLocation"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actor/hasOrganisationName"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Person or group of people that has its own functions with responsibilities, authorities, and relationships to achieve its objectives. The concept of organization includes, but is not limited to sole-trader, company, corporation, firm, enterprise, authority, partnership, charity or institution, or part or combination thereof, whether incorporated or not, public or private (e.g. foundation, union, association, agency, municipality, region, country, intergovernmental agencies). A group of organizations can also be considered as	an organization that has, alone or collectively,their own objectives.</rdfs:comment>
        <rdfs:isDefinedBy>ISO 59004:2024 - 3.4.1 organization</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Organisation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/OrganisationLocation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/OrganisationLocation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/location/Location"/>
        <rdfs:comment>Location of an organisation</rdfs:comment>
        <rdfs:label>Organisation Location</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/OwningResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/OwningResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/owner"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the owner of a certain resource.</rdfs:comment>
        <rdfs:label>Owning resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/Person -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/Person">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
        <rdfs:label xml:lang="en">Person</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/ProcessParticipation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/ProcessParticipation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/CollaborationParticipation"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/CollaborationParticipation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/actor/ActorProcessRole"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participatingActor"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participationIn"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/processODP/Process"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>Participation of a certain actor in a certain process, with a certain role. For instance, a certain department of a recycling company having the role of quality controllant, or material sorter, in a certain recycling process. The participation may also be given a time, e.g. a start and end time.</rdfs:comment>
        <rdfs:label>Process Participation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/ProducingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/ProducingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/producer"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the producer of a certain resource.</rdfs:comment>
        <rdfs:label>Producing resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/ProvidingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/ProvidingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/provider"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the provider of a certain resource.</rdfs:comment>
        <rdfs:label>Providing resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/RepairingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/RepairingResource">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/ResellingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/ResellingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/reseller"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the reseller of a certain resource.</rdfs:comment>
        <rdfs:label>Reselling resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/SellingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/SellingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/seller"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the seller of a certain resource.</rdfs:comment>
        <rdfs:label>Selling resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/Stakeholder -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/Stakeholder">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actor/Organisation"/>
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actor/Person"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Person or organization that can affect, be affected by, or perceive itself to be affected by a decision or activity. To “perceive itself to be affected” means the perception has been made known to the organization.</rdfs:comment>
        <rdfs:isDefinedBy>ISO 59004:2024 - 3.4.2 interested party, stakeholder</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Stakeholder</rdfs:label>
        <rdfs:label>Interested Party</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/SupplyingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/SupplyingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/supplier"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the supplier of a certain resource.</rdfs:comment>
        <rdfs:label>Supplying resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/UpdatingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/UpdatingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/updater"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the updater of a certain resource.</rdfs:comment>
        <rdfs:label>Updating resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/UsingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/UsingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/user"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the user of a certain resource.</rdfs:comment>
        <rdfs:label>Using resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actor/ViewingResource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actor/ViewingResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:hasValue rdf:resource="http://w3id.org/CEON/ontology/actor/viewer"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>The relation where the role of the actor is the viewer of a certain resource.</rdfs:comment>
        <rdfs:label>Viewing resource</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/Actor -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/Actor">
        <rdfs:comment>An agent able to act in the context of a circular value network, e.g. an organisation, person.</rdfs:comment>
        <rdfs:label>Actor</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/ActorType -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/ActorType">
        <rdfs:comment>The type of an actor, e.g. the type of company, or a specific subtype based on the organisations capabilities.</rdfs:comment>
        <rdfs:label>Actor Type</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/Capability -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/Capability">
        <rdfs:comment>Something that the actor is capable of doing, e.g. perfomring a certain role in a process, based on some properties, such as access to infrastructure, resources and know-how.</rdfs:comment>
        <rdfs:label>Capability</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/CollaborationParticipation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/CollaborationParticipation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:comment>The relation involving the role of a certain actor with respect to a value network or a process in such a network, e.g. an organisation (actor) acting as the recycler (role) in a glass recycling value netowrk (network) at a specific point or period in time. Or an organisation (actor) acting as the dismantler (role) in a dismantling step of a building deconstruction process (process step) at a specific point or period in time.</rdfs:comment>
        <rdfs:label>Collaboration participation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/Infrastructure -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/Infrastructure">
        <rdfs:comment>An infrastructure refers to facilities, services, or systems for participations to function.</rdfs:comment>
        <rdfs:label>Infrastructure</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/Participation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/Participation">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participationStartTime"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participationTimePoint"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>Represents the participation of objects in some situation.</rdfs:comment>
        <rdfs:label>Participation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/ResourceParticipation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceParticipation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:comment>The generic relation representing the particpation of a resource in some relation. For example, it can be specialized to represent a reified version of an object or data property.</rdfs:comment>
        <rdfs:label>Resource participation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/ResourceRelation -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/ResourceRelation">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/Participation"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/Participation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participantRole"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/actor/ActorResourceRole"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participatingActor"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/actorODP/Actor"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/CEON/ontology/actorODP/participatingResource"/>
                        <owl:someValuesFrom rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A relation between a resource, an actor, and the role the actor has in relation to the resource. For instance, the role of owner that a certain actor takes for a certain resource for a certain period of time. Or the seller of a certain resource, until that resource has been sold, and the actor no longer has that role in relation to the resource.</rdfs:comment>
        <rdfs:comment>The relation involving the role of a certain actor with respect to a certain resource, e.g. an organisation or individual (actor) owning (role) a specific product (resource) at a specific point or period in time.</rdfs:comment>
        <rdfs:label>Resource Relation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/actorODP/Role -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/actorODP/Role">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Role"/>
        <rdfs:comment>A role that an actor can take in a specific context. Applies both to roles in the context of resources, such as owner, manufacturer, reseller etc. of that resource, as well as roles in relation to a circular value network, such as recycler, dismantler, transporter etc., in relation to a material flow.</rdfs:comment>
        <rdfs:label>Role</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/cvn/CVN -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/cvn/CVN">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/cvn/Collaboration"/>
        <rdfs:comment xml:lang="en">A network of interlinked value chains and interested parties.</rdfs:comment>
        <rdfs:isDefinedBy>ISO 59004:2024 - 3.5.3 value network</rdfs:isDefinedBy>
        <rdfs:label>Circular Value Network</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/cvn/CVNBlueprint -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/cvn/CVNBlueprint">
        <rdfs:comment>A plan or a pattern of a CVN configuration that can then be filled with actual actors and processes. The blueprint can be used to capture a desired setup of a network, or for reusing patterns of CVNs.</rdfs:comment>
        <rdfs:label>Circular Value Network Blueprint</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/cvn/CircularStrategy -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/cvn/CircularStrategy">
        <rdfs:comment>A circular strategy, such as to reccycle, reuse or refurbish something.</rdfs:comment>
        <rdfs:label>Circular Strategy</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/cvn/Collaboration -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/cvn/Collaboration">
        <rdfs:comment>A collaboration between a set of actors.</rdfs:comment>
        <rdfs:label>Collaboration</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/Biofuel -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/Biofuel">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/Biomass"/>
        <rdfs:comment>Biofuel is a fuel that is produced over a short time span from biomass.</rdfs:comment>
        <rdfs:label>Biofuel</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Biofuel</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/Biogas -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/Biogas">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/Biomass"/>
        <rdfs:comment>Biogas represents an energy source that is produced from raw materials such as agricultural waste, manure, municipal waste, plant material, sewage, green waste, wastewater, and food waste.</rdfs:comment>
        <rdfs:label>Biogass</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Biogas</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/Biomass -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/Biomass">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/EnergySource"/>
        <rdfs:comment>Biomass represents matter from recently living (but now dead) organisms such as plants, algae and animals.</rdfs:comment>
        <rdfs:label>Biomass</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Biomass</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/Coal -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/Coal">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/FossilFuel"/>
        <rdfs:comment>Coal is a black or dark-brown combustible mineral substance consisting of carbonized vegetable matter.</rdfs:comment>
        <rdfs:label>Coal</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Coal</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/Energy -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/Energy">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/resourceODP/Resource"/>
        <rdfs:comment>An amount of energy.</rdfs:comment>
        <rdfs:comment>Energy is an ability or a property of matter or a system, to do work because of its motion, its mass, its electric charge, etc.</rdfs:comment>
        <rdfs:label>Energy</rdfs:label>
        <rdfs:seeAlso>http://emmo.info/emmo#EMMO_31ec09ba_1713_42cb_83c7_b38bf6f9ced2</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/EnergyComposition -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/EnergyComposition">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceParticipation"/>
        <rdfs:comment>The relation representing the particpation of an energy as a resource.</rdfs:comment>
        <rdfs:label>Energy Composition</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/EnergyConversion -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/EnergyConversion">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/ResourceRelation"/>
        <rdfs:comment>Energy Conversion is a process of transforming energy.</rdfs:comment>
        <rdfs:label>Energy Conversion</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/EnergyInfrastructure -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/EnergyInfrastructure">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/Infrastructure"/>
        <rdfs:comment>The infrastructures participating in various energy-related processes, including energy production, transmission or distribution.</rdfs:comment>
        <rdfs:label>Energy Infrastructure</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/EnergySource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/EnergySource">
        <rdfs:comment>An energy source is a resource or system that provides the energy.</rdfs:comment>
        <rdfs:label>Energy Source</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/FossilFuel -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/FossilFuel">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/EnergySource"/>
        <rdfs:comment>A fossil fuel is a carbon compound- or hydrocarbon-containing material[2] formed naturally in the Earth&apos;s crust from the buried remains of prehistoric organisms (animals, plants or planktons), a process that occurs within geological formations.</rdfs:comment>
        <rdfs:label>Fossil Fuel</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Fossil_fuel</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/GeothermalEnergySource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/GeothermalEnergySource">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/EnergySource"/>
        <rdfs:comment>Geothermal Energy Source is the Earth&apos;s crust. Geothermal energy is thermal energy extracted from the Earth&apos;s crust. It combines energy from the formation of the planet and from radioactive decay.</rdfs:comment>
        <rdfs:label>Geothermal Energy Source</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Geothermal_energy</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/Hydropower -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/Hydropower">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/EnergySource"/>
        <rdfs:comment>Hydropower is the use of falling or fast-running water to produce electricity or to power machines.</rdfs:comment>
        <rdfs:label>Hydropower</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Hydropower</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/NaturalGas -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/NaturalGas">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/FossilFuel"/>
        <rdfs:comment>Natural gas is a combustible gas that is naturally generated and stored under certain geological conditions by ancient animals and plants buried deep underground. It is a gaseous mixture of hydrocarbons and non-hydrocarbons, with methane as its main component.</rdfs:comment>
        <rdfs:label>Natural Gas</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Natural_gas</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/NonRenewableEnergy -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/NonRenewableEnergy">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/Energy"/>
        <rdfs:comment>Nonrenewable energy represents energy that comes from such resources that cannot be replaced onew they are used up.</rdfs:comment>
        <rdfs:label>NonReneable Energy</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/Petroleum -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/Petroleum">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/FossilFuel"/>
        <rdfs:comment>Petroleum is a naturally occurring yellow-black liquid chemical mixture found in geological formations, consisting primarily of hydrocarbons.</rdfs:comment>
        <rdfs:label>Petroleum</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Petroleum</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/RenewableEnergy -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/RenewableEnergy">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/Energy"/>
        <rdfs:comment>Renewable energy represents energy that comes from renewable resources.</rdfs:comment>
        <rdfs:label>Renewable Energy</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/CEON/ontology/energy/SolarEnergySource -->

    <owl:Class rdf:about="http://w3id.org/CEON/ontology/energy/SolarEnergySource">
        <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/energy/EnergySource"/>
        <rdfs:comment>Solar Energy Source is the Sun.</rdfs:comment>
        <rdfs:label>Solar Energy Source</rdfs:label>
        <rdfs:seeAlso>https://en.wikipedia.org/wiki/Solar_energy</rdfs:seeAlso>
    </owl:Class>
    


