        <qudt:uneceCommonCode>DLT</qudt:uneceCommonCode>
        <rdfs:isDefinedBy rdf:resource="http://qudt.org/2.1/vocab/unit"/>
        <rdfs:label xml:lang="en">Decilitre</rdfs:label>
        <rdfs:label xml:lang="en-us">Decilitre</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://qudt.org/vocab/unit/DeciM -->

    <owl:NamedIndividual rdf:about="http://qudt.org/vocab/unit/DeciM">
        <rdf:type rdf:resource="http://qudt.org/schema/qudt/Unit"/>
        <qudt:hasQuantityKind rdf:resource="http://qudt.org/vocab/quantitykind/Length"/>
        <dcterms:description rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML">A decimeter is a tenth of a meter.</dcterms:description>
        <qudt:prefix rdf:resource="http://qudt.org/vocab/prefix/Deci"/>
        <qudt:symbol>dm</qudt:symbol>
        <qudt:ucumCode rdf:datatype="http://qudt.org/schema/qudt/UCUMcs">dm</qudt:ucumCode>
        <qudt:uneceCommonCode>DMT</qudt:uneceCommonCode>
        <rdfs:isDefinedBy rdf:resource="http://qudt.org/2.1/vocab/unit"/>
        <rdfs:label xml:lang="en-us">Decimeter</rdfs:label>
        <rdfs:label xml:lang="en">Decimetre</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://qudt.org/vocab/unit/DeciM2 -->

    <owl:NamedIndividual rdf:about="http://qudt.org/vocab/unit/DeciM2">
        <rdf:type rdf:resource="http://qudt.org/schema/qudt/Unit"/>
        <qudt:hasQuantityKind rdf:resource="http://qudt.org/vocab/quantitykind/Area"/>
        <qudt:plainTextDescription>0.1-fold of the power of the SI base unit metre with the exponent 2</qudt:plainTextDescription>
